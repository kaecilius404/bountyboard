{
  "WordPress": {
    "headers": {"X-Powered-By": "WordPress"},
    "cookies": ["wordpress_", "wp-settings-", "wp_"],
    "body_patterns": ["wp-content/", "wp-includes/", "wp-json/", "xmlrpc.php"],
    "paths": ["/wp-admin/", "/wp-login.php", "/wp-json/"],
    "meta": {"generator": "WordPress"},
    "category": "CMS"
  },
  "Drupal": {
    "headers": {"X-Generator": "Drupal", "X-Drupal-Cache": ""},
    "cookies": ["Drupal.visitor.", "SESS"],
    "body_patterns": ["/sites/default/files/", "Drupal.settings", "drupal.js"],
    "paths": ["/user/login", "/admin/config"],
    "meta": {"generator": "Drupal"},
    "category": "CMS"
  },
  "Joomla": {
    "body_patterns": ["/media/jui/", "joomla!", "index.php?option=com_"],
    "paths": ["/administrator/", "/components/"],
    "meta": {"generator": "Joomla"},
    "category": "CMS"
  },
  "Magento": {
    "cookies": ["PHPSESSID", "frontend"],
    "body_patterns": ["Mage.Cookies", "mage/cookies", "/skin/frontend/"],
    "paths": ["/admin/", "/index.php/admin/"],
    "category": "CMS"
  },
  "Shopify": {
    "headers": {"X-ShopId": "", "X-ShopifyRequestId": ""},
    "body_patterns": ["cdn.shopify.com", "shopify.com/s/files"],
    "category": "CMS"
  },
  "Ghost": {
    "headers": {"X-Powered-By": "Ghost"},
    "body_patterns": ["ghost.io", "content/themes/"],
    "paths": ["/ghost/"],
    "category": "CMS"
  },
  "Laravel": {
    "cookies": ["laravel_session", "XSRF-TOKEN"],
    "body_patterns": ["laravel_session", "csrf-token"],
    "paths": ["/storage/logs/laravel.log"],
    "category": "Framework"
  },
  "Symfony": {
    "headers": {"X-Debug-Token": "", "X-Debug-Token-Link": ""},
    "body_patterns": ["sf-toolbar", "symfony"],
    "paths": ["/_profiler", "/_wdt"],
    "category": "Framework"
  },
  "Django": {
    "cookies": ["csrftoken", "sessionid"],
    "body_patterns": ["csrfmiddlewaretoken", "djdt", "__admin_media_prefix__"],
    "paths": ["/admin/", "/static/admin/"],
    "category": "Framework"
  },
  "Flask": {
    "cookies": ["session"],
    "headers": {"Server": "Werkzeug"},
    "body_patterns": ["Werkzeug", "Flask"],
    "category": "Framework"
  },
  "Ruby on Rails": {
    "cookies": ["_session_id", "_rails_session"],
    "headers": {"X-Runtime": "", "X-Powered-By": "Phusion Passenger"},
    "body_patterns": ["Rails.application.config", "data-turbo"],
    "category": "Framework"
  },
  "Express": {
    "headers": {"X-Powered-By": "Express"},
    "category": "Framework"
  },
  "Next.js": {
    "headers": {"X-Powered-By": "Next.js"},
    "body_patterns": ["__NEXT_DATA__", "_next/static/", "/_next/"],
    "category": "Framework"
  },
  "Nuxt": {
    "body_patterns": ["__nuxt", "window.__NUXT__", "/_nuxt/"],
    "category": "Framework"
  },
  "Spring Boot": {
    "cookies": ["JSESSIONID"],
    "headers": {"X-Application-Context": ""},
    "body_patterns": ["spring", "Whitelabel Error Page"],
    "paths": ["/actuator", "/actuator/health"],
    "category": "Framework"
  },
  "ASP.NET": {
    "cookies": ["ASP.NET_SessionId", "__RequestVerificationToken"],
    "headers": {"X-Powered-By": "ASP.NET", "X-AspNet-Version": ""},
    "body_patterns": ["__VIEWSTATE", "__EVENTVALIDATION"],
    "category": "Framework"
  },
  "FastAPI": {
    "body_patterns": ["FastAPI", "openapi.json"],
    "paths": ["/docs", "/redoc", "/openapi.json"],
    "category": "Framework"
  },
  "Angular": {
    "body_patterns": ["ng-version=", "angular.js", "@angular/core"],
    "category": "JavaScript Framework"
  },
  "React": {
    "body_patterns": ["react.production.min.js", "react-dom", "__reactFiber"],
    "category": "JavaScript Framework"
  },
  "Vue.js": {
    "body_patterns": ["vue.min.js", "vue.runtime.min.js", "__vue__"],
    "category": "JavaScript Framework"
  },
  "Apache": {
    "headers": {"Server": "Apache"},
    "body_patterns": ["Apache/", "Apache HTTP Server"],
